                        </div>
                    </div>
                    
                    <button class="mobile-menu-btn" onclick="toggleMobileMenu()">☰</button>
                </div>
            </div>
        </nav>
        
        <!-- Mobile Menu -->
        <div class="mobile-menu-overlay" onclick="toggleMobileMenu()"></div>
        <div class="mobile-menu">
            <button class="mobile-close" onclick="toggleMobileMenu()">×</button>
            <a href="#" class="nav-link active" onclick="toggleMobileMenu()">
                <span class="icon">🏠</span>
                <span>首页</span>
            </a>
            <a href="#subjects" class="nav-link" onclick="toggleMobileMenu()">
                <span class="icon">📚</span>
                <span>学习</span>
            </a>
            <a href="#pbl" class="nav-link" onclick="toggleMobileMenu()">
                <span class="icon">🚀</span>
                <span>PBL项目</span>
            </a>
        </div>
        
        <!-- Main Content -->
        <main>
            <div class="container">
                <!-- Hero Section -->
                <section class="hero">
                    <div class="hero-grid">
                        <div class="hero-content">
                            <h1>Hi, Teresa! ✨</h1>
                            <p>欢迎来到你的专属 AI 学习乐园！每天进步一点点，成为更好的自己！</p>
                            
                            <div class="hero-stats">
                                <div class="stat-card">
                                    <div class="stat-value" id="booksCount">0</div>
                                    <div class="stat-label">阅读书籍</div>
                                </div>
                                <div class="stat-card">
                                    <div class="stat-value" id="wordsCount">0</div>
                                    <div class="stat-label">学习词汇</div>
                                </div>
                                <div class="stat-card">
                                    <div class="stat-value" id="streakCount">0</div>
                                    <div class="stat-label">连续天数</div>
                                </div>
                            </div>
                        </div>
                        
                        <div class="hero-visual">
                            <div class="hero-avatar-large">🦋</div>
                            <div class="hero-level">Level 12</div>
                        </div>
                    </div>
                </section>
                
                <!-- Progress Section -->
                <section class="progress-section">
                    <div class="progress-header">
                        <span class="progress-title">📊 今日学习进度</span>
                        <span class="progress-percent" id="progressPercent">0%</span>
                    </div>
                    <div class="progress-bar">
                        <div class="progress-fill" id="progressFill" style="width: 0%"></div>
                    </div>
                </section>
                
                <!-- Subjects Section -->
                <section class="section" id="subjects">
                    <div class="section-header">
                        <h2 class="section-title">
                            <span class="icon">📖</span>
                            学习科目
                        </h2>
                    </div>
                    
                    <div class="subjects-grid">
                        <!-- English -->
                        <div class="subject-card english" onclick="openChat('english')">
                            <div class="subject-icon">📖</div>
                            <h3>English 英语</h3>
                            <p>阅读 · 词汇 · 口语</p>
                            <ul class="subject-tasks">
                                <li>
                                    <span class="task-check" onclick="toggleTask(event, 'english', 'reading')"></span>
                                    <span>阅读 Because of Winn-Dixie</span>
                                </li>
                                <li>
                                    <span class="task-check" onclick="toggleTask(event, 'english', 'vocabulary')"></span>
                                    <span>学习新单词</span>
                                </li>
                                <li>
                                    <span class="task-check" onclick="toggleTask(event, 'english', 'speaking')"></span>
                                    <span>口语练习</span>
                                </li>
                            </ul>
                            <button class="btn btn-primary btn-full" onclick="event.stopPropagation(); openChat('english')">
                                🤖 开始学习
                            </button>
                        </div>
                        
                        <!-- Math -->
                        <div class="subject-card math" onclick="openChat('math')">
                            <div class="subject-icon">🔢</div>
                            <h3>Math 数学</h3>
                            <p>计算 · 思维 · 奥数</p>
                            <ul class="subject-tasks">
                                <li>
                                    <span class="task-check" onclick="toggleTask(event, 'math', 'practice')"></span>
                                    <span>课内练习</span>
                                </li>
                                <li>
                                    <span class="task-check" onclick="toggleTask(event, 'math', 'olympiad')"></span>
                                    <span>每日奥数</span>
                                </li>
                                <li>
                                    <span class="task-check" onclick="toggleTask(event, 'math', 'wrongnotes')"></span>
                                    <span>错题复习</span>
                                </li>
                            </ul>
                            <button class="btn btn-primary btn-full" onclick="event.stopPropagation(); openChat('math')">
                                🤖 开始学习
                            </button>
                        </div>
                        
                        <!-- Chinese -->
                        <div class="subject-card chinese" onclick="openChat('chinese')">
                            <div class="subject-icon">📝</div>
                            <h3>Chinese 中文</h3>
                            <p>阅读 · 写作 · 日记</p>
                            <ul class="subject-tasks">
                                <li>
                                    <span class="task-check" onclick="toggleTask(event, 'chinese', 'reading')"></span>
                                    <span>中文阅读</span>
                                </li>
                                <li>
                                    <span class="task-check" onclick="toggleTask(event, 'chinese', 'diary')"></span>
                                    <span>写日记</span>
                                </li>
                                <li>
                                    <span class="task-check" onclick="toggleTask(event, 'chinese', 'writing')"></span>
                                    <span>写作练习</span>
                                </li>
                            </ul>
                            <button class="btn btn-primary btn-full" onclick="event.stopPropagation(); openChat('chinese')">
                                🤖 开始学习
                            </button>
                        </div>
                        
                        <!-- Science -->
                        <div class="subject-card science" onclick="openChat('science')">
                            <div class="subject-icon">🔬</div>
                            <h3>Science 科学</h3>
                            <p>实验 · 观察 · 探索</p>
                            <ul class="subject-tasks">
                                <li>
                                    <span class="task-check" onclick="toggleTask(event, 'science', 'observation')"></span>
                                    <span>自然观察</span>
                                </li>
                                <li>
                                    <span class="task-check" onclick="toggleTask(event, 'science', 'experiment')"></span>
                                    <span>小实验</span>
                                </li>
                            </ul>
                            <button class="btn btn-primary btn-full" onclick="event.stopPropagation(); openChat('science')">
                                🤖 开始探索
                            </button>
                        </div>
                    </div>
                </section>
                
                <!-- PBL Section -->
                <section class="section" id="pbl">
                    <div class="section-header">
                        <h2 class="section-title">
                            <span class="icon">🚀</span>
                            本周 PBL 项目
                        </h2>
                    </div>
                    
                    <div class="pbl-grid">
                        <div class="pbl-card" onclick="selectPBL(1)">
                            <span class="pbl-tag">World Study</span>
                            <div class="pbl-emoji">🗾</div>
                            <h4>探索日本文化</h4>
                            <p>了解日本的传统节日、美食、动漫文化</p>
                            <div class="pbl-meta">
                                <span>⏱️ 5天</span>
                                <span>🎯 英语/研究</span>
                            </div>
                        </div>
                        
                        <div class="pbl-card" onclick="selectPBL(2)">
                            <span class="pbl-tag">跨学科</span>
                            <div class="pbl-emoji">🍰</div>
                            <h4>数学与烹饪</h4>
                            <p>用食谱学习分数和测量</p>
                            <div class="pbl-meta">
                                <span>⏱️ 3天</span>
                                <span>🎯 数学/实践</span>
                            </div>
                        </div>
                        
                        <div class="pbl-card" onclick="selectPBL(3)">
                            <span class="pbl-tag">科学探究</span>
                            <div class="pbl-emoji">🌱</div>
                            <h4>植物生长观察</h4>
                            <p>种植豆芽，记录生长过程</p>
                            <div class="pbl-meta">
                                <span>⏱️ 7天</span>
                                <span>🎯 科学/观察</span>
                            </div>
                        </div>
                        
                        <div class="pbl-card" onclick="selectPBL(4)">
                            <span class="pbl-tag">社会探索</span>
                            <div class="pbl-emoji">🏘️</div>
                            <h4>社区调研</h4>
                            <p>访谈邻居，了解社区故事</p>
                            <div class="pbl-meta">
                                <span>⏱️ 4天</span>
                                <span>🎯 社交/表达</span>
                            </div>
                        </div>
                        
                        <div class="pbl-card" onclick="selectPBL(5)">
                            <span class="pbl-tag">艺术创作</span>
                            <div class="pbl-emoji">🎨</div>
                            <h4>绘本创作</h4>
                            <p>用英语创作自己的绘本故事</p>
                            <div class="pbl-meta">
                                <span>⏱️ 5天</span>
                                <span>🎯 英语/创意</span>
                            </div>
                        </div>
                        
                        <div class="pbl-card" onclick="selectPBL(6)">
                            <span class="pbl-tag">工程设计</span>
                            <div class="pbl-emoji">🏗️</div>
                            <h4>小桥建筑师</h4>
                            <p>用积木搭建能承重的小桥</p>
                            <div class="pbl-meta">
                                <span>⏱️ 3天</span>
                                <span>🎯 工程/数学</span>
                            </div>
                        </div>
                    </div>
                </section>
                
                <!-- Quick Actions -->
                <section class="section">
                    <div class="section-header">
                        <h2 class="section-title">
                            <span class="icon">⚡</span>
                            快速开始
                        </h2>
                    </div>
                    
                    <div class="quick-grid">
                        <div class="quick-card" onclick="openChat('reading')">
                            <div class="quick-icon">📚</div>
                            <h4>阅读时间</h4>
                            <p>Because of Winn-Dixie</p>
                        </div>
                        <div class="quick-card" onclick="openChat('world')">
                            <div class="quick-icon">🌍</div>
                            <h4>世界探索</h4>
                            <p>本周：日本</p>
                        </div>
                        <div class="quick-card" onclick="openChat('pbl')">
                            <div class="quick-icon">🎯</div>
                            <h4>我的项目</h4>
                            <p>查看PBL进度</p>
                        </div>
                        <div class="quick-card" onclick="showToast('💪', '加油！你是最棒的！')">
                            <div class="quick-icon">⭐</div>
                            <h4>自我鼓励</h4>
                            <p>给自己打气</p>
                        </div>
                    </div>
                </section>
            </div>
        </main>
        
        <!-- Footer -->
        <footer class="footer">
            <div class="container">
                <div class="footer-inner">
                    <div class="footer-brand">
                        <span class="logo">🦋</span>
                        <span>Teresa's AI Learning Hub</span>
                    </div>
                    <div class="footer-info">
                        <p>由 AI 助手提供服务</p>
                        <p class="text-muted">🤖 讯飞星火 · Kimi · 学而思九章</p>
                    </div>
                </div>
            </div>
        </footer>
    </div>
    
    <!-- Chat Modal -->
    <div class="modal-overlay" id="chatModal" onclick="closeModalOutside(event)">
        <div class="modal">
            <div class="modal-header">
                <div class="modal-avatar" id="modalAvatar">📖</div>
                <div class="modal-title">
                    <h3 id="modalTitle">英语老师</h3>
                    <p id="modalStatus">在线 · 随时为你解答</p>
                </div>
                <button class="modal-close" onclick="closeChat()">×</button>
            </div>
            <div class="modal-body" id="chatBody">
                <!-- Messages will be added here -->
            </div>
            <div class="modal-footer">
                <input type="text" id="chatInput" placeholder="输入你的问题或回答..." onkeypress="handleEnter(event)">
                <button class="btn btn-primary" onclick="sendMessage()">发送</button>
            </div>
        </div>
    </div>
    
    <!-- Celebration Modal -->
    <div class="celebrate-overlay" id="celebrateModal" onclick="closeCelebrate()">
        <div class="celebrate-modal">
            <div class="celebrate-emoji" id="celebrateEmoji">🎉</div>
            <h2 id="celebrateTitle">太棒了！</h2>
            <p id="celebrateText">你完成得很好！</p>
        </div>
    </div>
    
    <!-- Toast -->
    <div class="toast" id="toast">
        <div class="toast-content">
            <span id="toastIcon">✓</span>
            <span id="toastMessage">操作成功</span>
        </div>
    </div>

    <script>
        // ==================== Data & State ====================
        const TASKS = [
            { id: 'english-reading', subject: 'english', key: 'reading', title: '阅读 Because of Winn-Dixie' },
            { id: 'english-vocabulary', subject: 'english', key: 'vocabulary', title: '学习新单词' },
            { id: 'english-speaking', subject: 'english', key: 'speaking', title: '口语练习' },
            { id: 'math-practice', subject: 'math', key: 'practice', title: '课内练习' },
            { id: 'math-olympiad', subject: 'math', key: 'olympiad', title: '每日奥数' },
            { id: 'math-wrongnotes', subject: 'math', key: 'wrongnotes', title: '错题复习' },
            { id: 'chinese-reading', subject: 'chinese', key: 'reading', title: '中文阅读' },
            { id: 'chinese-diary', subject: 'chinese', key: 'diary', title: '写日记' },
            { id: 'chinese-writing', subject: 'chinese', key: 'writing', title: '写作练习' },
            { id: 'science-observation', subject: 'science', key: 'observation', title: '自然观察' },
            { id: 'science-experiment', subject: 'science', key: 'experiment', title: '小实验' }
        ];
        
        const SUBJECTS = {
            english: { title: '英语老师', avatar: '📖', status: 'Ready to practice!' },
            math: { title: '数学老师', avatar: '🔢', status: 'Let\'s solve problems!' },
            chinese: { title: '中文老师', avatar: '📝', status: '我们来写作吧！' },
            science: { title: '科学老师', avatar: '🔬', status: '探索科学世界！' },
            reading: { title: '阅读老师', avatar: '📚', status: '一起读书吧！' },
            world: { title: '世界探索', avatar: '🌍', status: '环游世界！' },
            pbl: { title: 'PBL 导师', avatar: '🎯', status: '来做项目吧！' }
        };
        
        let currentSubject = '';
        let doneTasks = new Set();
        
        // ==================== Initialization ====================
        document.addEventListener('DOMContentLoaded', () => {
            loadProgress();
            loadStats();
            updateProgress();
        });
        
        // ==================== Progress Management ====================
        function loadProgress() {
            const saved = localStorage.getItem('teresa_tasks');
            if (saved) {
                doneTasks = new Set(JSON.parse(saved));
                updateTaskChecks();
            }
        }
        
        function saveProgress() {
            localStorage.setItem('teresa_tasks', JSON.stringify([...doneTasks]));
        }
        
        function toggleTask(event, subject, key) {
            event.stopPropagation();
            const id = `${subject}-${key}`;
            
            if (doneTasks.has(id)) {
                doneTasks.delete(id);
            } else {
                doneTasks.add(id);
                showCelebrate('🌟', '任务完成！', '你做得真好！');
            }
            
            updateTaskChecks();
            updateProgress();
            saveProgress();
        }
        
        function updateTaskChecks() {
            document.querySelectorAll('.task-check').forEach(check => {
                const onclick = check.getAttribute('onclick');
                const match = onclick.match(/'([^']+)',\s*'([^']+)'/);
                if (match) {
                    const [, subject, key] = match;
                    const id = `${subject}-${key}`;
                    check.classList.toggle('done', doneTasks.has(id));
                }
            });
        }
        
        function updateProgress() {
            const total = TASKS.length;
            const done = doneTasks.size;
            const percent = total > 0 ? Math.round(done / total * 100) : 0;
            
            document.getElementById('progressPercent').textContent = percent + '%';
            document.getElementById('progressFill').style.width = percent + '%';
            
            if (percent === 100) {
                showCelebrate('🎉', '全部完成！', '你是最棒的学习小能手！');
            }
        }
        
        function loadStats() {
            // Simulated stats - in production, fetch from API
            const stats = JSON.parse(localStorage.getItem('teresa_stats') || '{}');
            document.getElementById('booksCount').textContent = stats.books || 0;
            document.getElementById('wordsCount').textContent = stats.words || 0;
            document.getElementById('streakCount').textContent = stats.streak || 0;
        }
        
        // ==================== PBL Selection ====================
        function selectPBL(id) {
            document.querySelectorAll('.pbl-card').forEach((card, index) => {
                card.classList.toggle('selected', index === id - 1);
            });
            showCelebrate('🎉', '项目已选中！', '准备好开始探索了吗？');
        }
        
        // ==================== Chat System ====================
        function openChat(subject) {
            currentSubject = subject;
            const config = SUBJECTS[subject] || { title: 'AI 老师', avatar: '🤖', status: '在线' };
            
            document.getElementById('modalTitle').textContent = config.title;
            document.getElementById('modalAvatar').textContent = config.avatar;
            document.getElementById('modalStatus').textContent = config.status;
            
            // Welcome messages
            const messages = {
                english: "Hi! I'm your English teacher! 📖\n\nLet's practice! What did you read today?",
                math: "Hi there! 🧮\n\nReady for some fun math? Let's solve some problems together!",
                chinese: "你好！📝\n\n今天想写什么日记呢？告诉我今天最开心的事！",
                science: "Welcome, little scientist! 🔬\n\nWhat do you want to explore today?",
                reading: "Hello, little reader! 📚\n\nLet's talk about your book!",
                world: "Hello, explorer! 🌍\n\nThis week we're learning about Japan!",
                pbl: "Welcome to PBL time! 🎯\n\nLet's work on your project!"
            };
            
            const body = document.getElementById('chatBody');
            body.innerHTML = '';
            addMessage(config.avatar, messages[subject] || "Hi Teresa! What would you like to learn?", 'ai');
            
            document.getElementById('chatModal').classList.add('active');
            document.getElementById('chatInput').focus();
        }
        
        function closeChat() {
            document.getElementById('chatModal').classList.remove('active');
            currentSubject = '';
        }
        
        function closeModalOutside(event) {
            if (event.target.id === 'chatModal') {
                closeChat();
            }
        }
        
        function handleEnter(event) {
            if (event.key === 'Enter') {
                sendMessage();
            }
        }
        
        function addMessage(avatar, text, sender) {
            const body = document.getElementById('chatBody');
            const div = document.createElement('div');
            div.className = `chat-message ${sender}`;
            div.innerHTML = `
                <div class="chat-avatar">${avatar}</div>
                <div class="chat-bubble">${text.replace(/\n/g, '<br>')}</div>
            `;
            body.appendChild(div);
            body.scrollTop = body.scrollHeight;
        }
        
        function addTyping() {
            const body = document.getElementById('chatBody');
            const div = document.createElement('div');
            div.className = 'chat-message ai';
            div.id = 'typingIndicator';
            div.innerHTML = `
                <div class="chat-avatar">🤖</div>
                <div class="chat-bubble">
                    <div class="typing-indicator">
                        <span></span><span></span><span></span>
                    </div>
                </div>
            `;
            body.appendChild(div);
            body.scrollTop = body.scrollHeight;
        }
        
        function removeTyping() {
            document.getElementById('typingIndicator')?.remove();
        }
        
        function sendMessage() {
            const input = document.getElementById('chatInput');
            const message = input.value.trim();
            
            if (!message) return;
            
            // Add user message
            const config = SUBJECTS[currentSubject] || { avatar: '👧' };
            addMessage('👧', message, 'user');
            input.value = '';
            
            // Show typing indicator
            addTyping();
            
            // Simulate AI response
            setTimeout(() => {
                removeTyping();
                const response = getAIResponse(currentSubject, message);
                addMessage(config.avatar, response, 'ai');
                
                // Update progress when user interacts
                updateProgress();
            }, 1000);
        }
        
        // ==================== AI Response Logic ====================
        function getAIResponse(subject, message) {
            const lower = message.toLowerCase();
            
            switch(subject) {
                case 'english':
                    if (lower.includes('book') || lower.includes('winn-dixie')) {
                        return "📖 Winn-Dixie is such a sweet dog! 🐕\n\nWhat do you think about him? Is he friendly? Tell me about your favorite part!";
                    }
                    if (lower.includes('word') || lower.includes('vocabulary')) {
                        return "📝 Great! Let's learn a new word!\n\nToday's word: <b>wonderful</b> (精彩的)\n\nExample: 'This is a wonderful day!'\n\nCan you use it in a sentence?";
                    }
                    if (lower.includes('speak') || lower.includes('say')) {
                        return "🗣️ Perfect! Your pronunciation is getting better!\n\nTry: 'The sun is shining brightly today.'\n\nGreat job! Keep practicing! 🌟";
                    }
                    return "🌟 Excellent work!\n\nKeep up the great effort! You're making amazing progress!\n\nWhat else would you like to learn?";
                
                case 'math':
                    if (lower.includes('规律') || lower.includes('pattern')) {
                        return "🔢 Fun pattern puzzle!\n\nLook: 2, 4, 6, 8, __?\n\nAnswer: 10! Because we add 2 each time!\n\nYour turn: 1, 3, 5, 7, __? 🤔";
                    }
                    if (lower.includes('难') || lower.includes('hard') || lower.includes('help')) {
                        return "💪 Don't worry! Let's figure it out together!\n\nTip: Break big problems into small steps.\n\nExample: 15 + 7 = ?\n→ 15 + 5 = 20\n→ 20 + 2 = 22\n\nSee? Easy! 🎉";
                    }
                    return "🧮 You're doing great!\n\nMath is like a puzzle - fun and exciting!\n\nReady for today's challenge? Let's go! 🚀";
                
                case 'chinese':
                    return "📝 Great writing! ✨\n\nIdeas for your diary:\n- What made you happy today?\n- What did you learn new?\n- What are you excited about tomorrow?\n\nKeep writing! You're doing awesome! 💕";
                
                case 'science':
                    return "🔬 Science is amazing! 🌟\n\nFun facts:\n- Plants need sun ☀️ and water 💧\n- Rainbows have 7 colors 🌈\n- Ice floats because it's less dense than water!\n\nWhat would you like to explore?";
                
                case 'world':
                    return "🌍 Let's explore Japan! 🇯🇵\n\nFun things about Japan:\n- 🗻 Mt. Fuji - beautiful mountain\n- 🌸 Cherry blossoms in spring\n- 🍣 Sushi - delicious food!\n\nWhat interests you most?";
                
                case 'pbl':
                    return "🎯 PBL is about learning by doing!\n\nSteps:\n1. Choose a topic\n2. Ask questions\n3. Find answers\n4. Create something\n5. Share with others\n\nWhat project are you working on?";
                
                default:
                    return "🌟 You're doing great!\n\nKeep learning and having fun!\n\nWhat would you like to explore next?";
            }
        }
        
        // ==================== UI Helpers ====================
        function showCelebrate(emoji, title, text) {
            document.getElementById('celebrateEmoji').textContent = emoji;
            document.getElementById('celebrateTitle').textContent = title;
            document.getElementById('celebrateText').textContent = text;
            document.getElementById('celebrateModal').classList.add('active');
            
            setTimeout(() => {
                closeCelebrate();
            }, 3000);
        }
        
        function closeCelebrate() {
            document.getElementById('celebrateModal').classList.remove('active');
        }
        
        function showToast(icon, message) {
            document.getElementById('toastIcon').textContent = icon;
            document.getElementById('toastMessage').textContent = message;
            document.getElementById('toast').classList.add('show');
            
            setTimeout(() => {
                document.getElementById('toast').classList.remove('show');
            }, 3000);
        }
        
        function toggleMobileMenu() {
            document.querySelector('.mobile-menu').classList.toggle('open');
            document.querySelector('.mobile-menu-overlay').classList.toggle('open');
        }
    </script>
</body>
</html>
