{
    "system": {
        "name": "Teresa 18周Homeschool系统",
        "version": "3.4",
        "adjustment": "PBL按原始18周计划配置 - 动物为主，拓宽人文艺术体育"
    },
    "pbl_structure": {
        "animals": {
            "description": "爬虫/蛇为核心，辐射全动物（蛇、蜥蜴、两栖、哺乳、鸟类、海洋动物等）"
        },
        "humanities": {
            "description": "日记、读后感、学习计划、演讲、写作"
        },
        "arts": {
            "description": "绘画、手工、创作"
        },
        "sports": {
            "description": "网球训练记录、运动分析"
        }
    },
    "phase_themes": {
        "phase1": {
            "name": "自我与习惯",
            "weeks": "1-4",
            "pbl_themes": [
                {"week": 1, "theme": "我的爱好（爬虫/网球/象棋）", "focus": "动物观察+绘画+写作"},
                {"week": 2, "theme": "动物观察笔记", "focus": "记录小动物"},
                {"week": 3, "theme": "动物故事", "focus": "读后感+手工"},
                {"week": 4, "theme": "我的学习计划", "focus": "规划+时间线手工"}
            ]
        },
        "phase2": {
            "name": "自然与科学探究",
            "weeks": "5-8",
            "pbl_themes": [
                {"week": 5, "theme": "后院动物", "focus": "户外观察+记录"},
                {"week": 6, "theme": "爬虫vs两栖", "focus": "对比海报"},
                {"week": 7, "theme": "森林动物", "focus": "模型手工"},
                {"week": 8, "theme": "蛇的真相与传说", "focus": "研究+对比手工"}
            ]
        },
        "phase3": {
            "name": "世界动物大探索",
            "weeks": "9-12",
            "pbl_themes": [
                {"week": 9, "theme": "沙漠动物", "focus": "栖息地手工"},
                {"week": 10, "theme": "草原动物", "focus": "生态图"},
                {"week": 11, "theme": "海洋动物", "focus": "海洋爬虫手工"},
                {"week": 12, "theme": "雨林动物", "focus": "雨林模型"}
            ]
        },
        "phase4": {
            "name": "创造与表达",
            "weeks": "13-16",
            "pbl_themes": [
                {"week": 13, "theme": "爬虫小说", "focus": "9页英文故事书"},
                {"week": 14, "theme": "饲养箱设计", "focus": "设计图+材料清单"},
                {"week": 15, "theme": "创造新动物", "focus": "想象动物+介绍"},
                {"week": 16, "theme": "保护动物", "focus": "宣传海报"}
            ]
        },
        "phase5": {
            "name": "展示与复盘",
            "weeks": "17-18",
            "pbl_themes": [
                {"week": 17, "theme": "作品集", "focus": "整理+成长总结"},
                {"week": 18, "theme": "成果展示", "focus": "3分钟演讲"}
            ]
        }
    },
    "pbl_mix_by_phase": {
        "phase1": "动物60% + 艺术20% + 人文20%",
        "phase2": "动物70% + 科学20% + 艺术10%",
        "phase3": "动物80% + 人文20%",
        "phase4": "艺术40% + 人文30% + 动物30%",
        "phase5": "人文60% + 艺术40%"
    }
}
